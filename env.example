# Copy this file to `.env` in the repository root and fill in your own values.
# Do NOT commit the real `.env` file.

# Required for benchmark submission
AGENTDS_API_KEY=your_agentds_api_key_here
AGENTDS_TEAM_NAME=your_team_name_here

# Recommended local dataset directory.
# Example A (repo-local): ./agent_ds_healthcare
# Example B (external Windows path): D:/AgentDs/agent_ds_healthcare
CLAI_BASE_DIR=D:/AgentDs/agent_ds_healthcare

# Optional override for the raw receipt PDF folder used in Challenge 2.
# Upstream AgentDS-Healthcare uses `receipts_pdf/`.
# If your local folder is named `receipt/`, point this variable there instead.
CLAI_RECEIPT_DIR=D:/AgentDs/agent_ds_healthcare/receipt

# Optional legacy experiment knobs used by some notebooks
CLAI_BRANCH=paper_release
FEATURE_CACHE_MODE=versioned
FORCE_RETRAIN=0
